APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# قرص رفع الملفات العامة (صور عقارات، إثبات ملكية، عقود، إيصالات): public أو r2
FILESYSTEM_DISK_PUBLIC=public

QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2 (عند FILESYSTEM_DISK_PUBLIC=r2)
# من لوحة Cloudflare: R2 → Manage R2 API Tokens → إنشاء Token (Read & Write)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=domiraa
AWS_ENDPOINT=https://fc7168b33d5e917d813a2bd6e2d9cca2.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true
# رابط الوصول العام لملفات R2 (بدون / في النهاية). فعّل Public access للـ Bucket أو Custom domain ثم الصق الرابط هنا
R2_PUBLIC_URL=

VITE_APP_NAME="${APP_NAME}"
